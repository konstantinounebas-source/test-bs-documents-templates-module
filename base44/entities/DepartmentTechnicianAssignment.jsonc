      "type": "string",
      "description": "Reference to FactoryFinancialData"
    },
    "department_id": {
      "type": "string",
      "description": "Reference to Department"
    },
    "technician_rows": {
      "type": "array",
      "description": "List of technicians assigned to this department",
      "default": [],
