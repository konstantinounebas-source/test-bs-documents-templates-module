          "personnel_id": {
            "type": "string",
            "description": "Reference to LabourPersonnel"
          },
          "comments": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "factory_financial_data_id",
    "department_id"
  ]
}